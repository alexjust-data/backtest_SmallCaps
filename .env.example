# -----------------------------
# Cloudflare R2 (S3-compatible)
# -----------------------------
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET=your_bucket_name
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_REGION=auto

# Optional: if you use a custom domain endpoint for R2
# R2_ENDPOINT=https://storage.your-domain.com

# -----------------------------
# Data locations (local)
# -----------------------------
DATA_CACHE_DIR=./data/cache
DATA_DERIVED_DIR=./data/derived
RUNS_DIR=./runs

# -----------------------------
# Project defaults
# -----------------------------
PROJECT_TZ=America/New_York
CALENDAR=nyse

# -----------------------------
# Performance / behavior
# -----------------------------
PARQUET_ENGINE=pyarrow
MAX_WORKERS=8

# -----------------------------
# Logging
# -----------------------------
LOG_LEVEL=INFO

# -----------------------------
# Safety toggles
# -----------------------------
# If true, validation will fail on WARN thresholds too
STRICT_VALIDATION=false
