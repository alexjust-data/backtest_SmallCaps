     "shell.execute_reply": "2026-02-11T18:12:14.671150Z"
    }
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "shape: (1, 4)\n",
      "┌─────────────────┬─────────────────┬─────────────────┬────────────────────┐\n",
      "│ pct_range_le_1c ┆ pct_range_le_2c ┆ pct_range_le_5c ┆ p_in_range_overall │\n",
      "│ ---             ┆ ---             ┆ ---             ┆ ---                │\n",
      "│ f64             ┆ f64             ┆ f64             ┆ f64                │\n",
      "╞═════════════════╪═════════════════╪═════════════════╪════════════════════╡\n",
      "│ 0.029656        ┆ 0.1078          ┆ 0.545374        ┆ 0.807236           │\n",
