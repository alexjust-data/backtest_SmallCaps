     "text": [
      "shape: (5, 12)\n",
      "┌────────┬────────┬────────┬───────┬───────┬───────┬───────┬───────┬───────┬───────┬───────┬───────┐\n",
      "│ minute ┆ quote_ ┆ first_ ┆ last_ ┆ min_b ┆ max_a ┆ min_m ┆ max_m ┆ sprea ┆ sprea ┆ sprea ┆ cross │\n",
