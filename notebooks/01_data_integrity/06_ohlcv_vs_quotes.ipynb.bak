   "source": [
    "# Plots robustos: ordenar por tiempo, evitar spaghetti y agregar vista diaria\n",
    "\n",
    "plot_df = (\n",
    "    joined\n",
    "    .select([\"minute_ny\", \"mid_ref\", \"close\", \"spread_bps_med\", \"d_norm\"])\n",
    "    .drop_nulls([\"minute_ny\"])\n",
    "    .sort(\"minute_ny\")\n",
    "    .unique(subset=[\"minute_ny\"], keep=\"last\")\n",
    "    .collect()\n",
    ")\n",
    "\n",
    "if plot_df.height == 0:\n",
    "    print(\"[SKIP] no rows available for plotting\")\n",
    "else:\n",
    "    pdf = plot_df.to_pandas().sort_values(\"minute_ny\").reset_index(drop=True)\n",
    "\n",
    "    # Keep intraday view readable on long series\n",
    "    step = max(1, len(pdf) // 4000)\n",
    "    pdf_plot = pdf.iloc[::step].copy()\n",
    "\n",
    "    plt.figure(figsize=(12, 4))\n",
    "    plt.plot(pdf_plot[\"minute_ny\"], pdf_plot[\"mid_ref\"], label=\"mid_ref\", linewidth=1.0)\n",
    "    plt.plot(pdf_plot[\"minute_ny\"], pdf_plot[\"close\"], label=\"ohlcv_close\", linewidth=1.0, alpha=0.85)\n",
    "    plt.legend()\n",
    "    plt.title(\"OHLCV close vs Quotes mid_ref (sorted timeline)\")\n",
    "    plt.xticks(rotation=30)\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "    plt.figure(figsize=(12, 4))\n",
    "    plt.plot(pdf_plot[\"minute_ny\"], pdf_plot[\"spread_bps_med\"], linewidth=0.9)\n",
    "    plt.title(\"Spread (bps) median per minute (sorted timeline)\")\n",
    "    plt.xticks(rotation=30)\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "    plt.figure(figsize=(12, 4))\n",
    "    plt.plot(pdf_plot[\"minute_ny\"], pdf_plot[\"d_norm\"], linewidth=0.9)\n",
    "    plt.title(\"Normalized distance d_norm (sorted timeline)\")\n",
    "    plt.xticks(rotation=30)\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "    # Daily aggregation for scientific interpretation\n",
    "    day_df = (\n",
    "        plot_df\n",
    "        .with_columns(pl.col(\"minute_ny\").dt.date().alias(\"day\"))\n",
    "        .group_by(\"day\")\n",
    "        .agg([\n",
    "            pl.col(\"spread_bps_med\").median().alias(\"spread_bps_med_p50_day\"),\n",
    "            pl.col(\"d_norm\").median().alias(\"d_norm_p50_day\"),\n",
    "            pl.col(\"d_norm\").quantile(0.95, \"nearest\").alias(\"d_norm_p95_day\"),\n",
    "        ])\n",
    "        .sort(\"day\")\n",
    "        .to_pandas()\n",
    "    )\n",
    "\n",
    "    plt.figure(figsize=(12, 4))\n",
    "    plt.plot(day_df[\"day\"], day_df[\"spread_bps_med_p50_day\"], marker=\"o\", linewidth=1.2)\n",
    "    plt.title(\"Daily median spread (bps)\")\n",
    "    plt.xticks(rotation=30)\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "    plt.figure(figsize=(12, 4))\n",
    "    plt.plot(day_df[\"day\"], day_df[\"d_norm_p50_day\"], marker=\"o\", linewidth=1.2, label=\"d_norm p50\")\n",
    "    plt.plot(day_df[\"day\"], day_df[\"d_norm_p95_day\"], marker=\"o\", linewidth=1.2, label=\"d_norm p95\")\n",
    "    plt.legend()\n",
    "    plt.title(\"Daily d_norm summary\")\n",
    "    plt.xticks(rotation=30)\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n"
   ]
  },
